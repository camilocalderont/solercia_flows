        "hasOutputParser": true,
        "options": {
          "systemMessage": "=Clasificador de intenciones - Personería Mesitas del Colegio.\n\nCATEGORÍAS:\n{{ JSON.stringify($node[\"CompanyServices\"].json.services) }}\n\nESPECIALES:\n- welcome: saludos/presentaciones\n- finish: despedidas/agradecimientos\n\nINSTRUCCIONES:\nAnaliza el mensaje y clasifica según categorías. Para consultas específicas usa \"vc_name\" + su Id. Para saludos/despedidas usa welcome/finish + null.\n\nFORMATO:\n{\"intencion\": \"categoria_o_welcome_o_finish\", \"idIntencion\": numero_o_null}\n\nEJEMPLOS:\n\"Hola\" → {\"intencion\": \"welcome\", \"idIntencion\": null}\n\"Mi vecino hace ruido\" → {\"intencion\": \"Problemas de convivencia ciudadana\", \"idIntencion\": 3}\n\"Gracias\" → {\"intencion\": \"finish\", \"idIntencion\": null}"
        }
      },
