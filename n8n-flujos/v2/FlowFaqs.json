    {
      "parameters": {
        "operation": "executeQuery",
        "query": "select \n\tc.\"Id\",\n\tc.vc_name,\n\tc.tx_prompt,\n\tcpct.i_max_interaction_tokens,\n\tcpct.i_max_conversation_tokens,\n\tJSON_AGG(\n\t  JSON_BUILD_OBJECT(\n\t    'Id', cs.\"Id\",\n\t    'vc_name', cs.vc_name\n\t  )\n\t) as services\nfrom \"Company\" c \njoin \"CategoryService\" cs on cs.company_id = c.\"Id\" \njoin \"CompanyPlan\" cp on cp.company_id = c.\"Id\" \njoin \"CompanyPlanControlToken\" cpct on cpct.company_plan_id  = cp.\"Id\" \nwhere c.\"Id\" = '{{$node[\"Webhook\"].json.body.company_id}}'\ngroup by 1,2,3,4,5",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -1024,
        144
      ],
      "id": "ab21c2d6-6645-4907-9d70-21de34e3b737",
      "name": "CompanyServices",
      "credentials": {
        "postgres": {
          "id": "Z2mTqwzFo4gFozil",
          "name": "Boki"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "select\n  JSON_AGG(\n    JSON_BUILD_OBJECT(\n      'vc_question', f.vc_question,\n      'vc_answer',  f.vc_answer\n    )\n  ) as data_facs\nfrom \"Faqs\" f\nwhere category_service_id = '{{ $items(\"ContextAgent\")[0].json.output?.idIntencion\n  ? $items(\"ContextAgent\")[0].json.output.idIntencion\n  : 0 }}'\n",
        "options": {}
