    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n    COALESCE(sct.vc_session_id, '{{$node[\"Webhook\"].json.body.sessionId}}') as vc_session_id,\n    COALESCE(SUM(sct.\"tokensEntrada\"), 0) as \"tokensEntrada\",\n    COALESCE(SUM(sct.\"tokensSalida\"), 0) as \"tokensSalida\",\n    COALESCE(SUM(sct.\"tokensTotal\"), 0) as \"tokensTotal\"\nFROM (SELECT 1) as dummy\nLEFT JOIN \"SessionControlTokens\" sct \n    ON sct.vc_session_id = '{{$node[\"Webhook\"].json.body.sessionId}}'\nGROUP BY sct.vc_session_id",
