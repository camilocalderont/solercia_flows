# ===========================================
# BokiBot Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# NEVER commit the .env file to git

# --- Domain Configuration ---
DOMAIN_NAME=solercia.com.co
SUBDOMAIN_FLOWS=flows
SUBDOMAIN_DEV=devs
SUBDOMAIN_WEB=www
SUBDOMAIN_BOKI_API=boki-api
SUBDOMAIN_TRAEFIK=traefik

# --- Traefik ---
TRAEFIK_BASIC_AUTH_USER=
TRAEFIK_BASIC_AUTH_PASSWORD=

# --- General ---
GENERIC_TIMEZONE=America/Bogota

# --- SSL/TLS ---
ACME_EMAIL=

# --- PostgreSQL (shared: n8n + boki-api) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=          # CHANGE THIS - use a strong password
POSTGRES_SOLERCIA_DB=n8n    # n8n database name
POSTGRES_PORT=5432

# --- PostgreSQL (boki-api specific) ---
POSTGRES_DB_HOST=postgres
POSTGRES_DB_PORT=5432
POSTGRES_DB_USER=postgres
POSTGRES_DB_PASSWORD=       # Same as POSTGRES_PASSWORD
POSTGRES_DB_NAME=boki       # boki business database

# --- MongoDB ---
MONGO_USER=admin
MONGO_PASSWORD=             # CHANGE THIS - use a strong password
MONGO_DB_NAME=boki_mongo

# --- boki-api ---
API_VERSION=1
API_URL=https://boki-api.solercia.com.co
API_TOKEN=                  # Generate: openssl rand -base64 32

# --- JWT Authentication ---
JWT_SECRET=                 # Generate: openssl rand -base64 64

# --- LLM / AI ---
LLM_APIKEY=                 # OpenAI API key
LLM_MODEL=gpt-4o-mini
GEMINI_API_KEY=             # Google Gemini API key (for chatbot widget)

# --- Meta WhatsApp ---
META_BOT_TOKEN=
META_NUMBER_ID=
META_VERIFY_TOKEN=
META_VERSION=22.0

# --- Twilio (optional) ---
ACC_SID=
ACC_TOKEN=
ACC_VENDOR=

# --- n8n LLM ---
LLM_API_KEY=
LLM_API_NAME=

# --- Google Calendar (optional) ---
# https://docs.n8n.io/integrations/builtin/credentials/google/oauth-single-service/
